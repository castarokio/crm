# ============================================================
# Shopiii Bot — Environment Variables TEMPLATE
# Copy this file to .env and fill in your real values.
# NEVER put real credentials in this file.
# ============================================================

API_ID=YOUR_TELEGRAM_API_ID
API_HASH=YOUR_TELEGRAM_API_HASH
BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER

# Your Telegram user ID (owner of the bot)
OWNER_ID=YOUR_TELEGRAM_USER_ID

# Channel where hits are broadcast publicly
CHANNEL_ID=YOUR_CHANNEL_ID

# Channel where uploaded .txt card files are forwarded
FILES_CHANNEL_ID=YOUR_FILES_CHANNEL_ID

# ============================================================
# Optional Bot Configuration
# ============================================================
CHECKER_API_URL=http://62.72.20.10:8081/
REQUIRED_CHANNELS=@YourChannel1,@YourChannel2
CC_COOLDOWN_SECONDS=3
WORKER_COUNT=10
MAX_CARDS_PER_CHECK=5000
